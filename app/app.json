{
  "expo": {
    "name": "시티드",
    "slug": "jari-inna",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icons/jarijabi-icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/icons/jarijabi-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.paenda.seated"
    },
    "android": {
      "package": "com.paenda.seated",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icons/jarijabi-icon.png",
        "backgroundColor": "#FFFFFF"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/icons/jarijabi-icon.png"
    },
    "plugins": [
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true
          }
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "3c5e2cd8-9638-4b69-865f-b5ebf69db106"
      }
    }
  }
}
