{
  "expo": {
    "name": "시티드",
    "slug": "jari-inna",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#00A4E4"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.paenda.seated"
    },
    "android": {
      "package": "com.paenda.seated",
      "versionCode": 10,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#00A4E4"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true
          }
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "근처 지하철역을 자동으로 찾기 위해 위치 정보를 사용해요"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "3c5e2cd8-9638-4b69-865f-b5ebf69db106"
      }
    }
  }
}
